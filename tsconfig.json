{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "app/_layout.js",
    "app/index.js",
    "app/(drawer)/(services)/location.js",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
, "context/AuthContext.js", "app/language.js"  ]
}
