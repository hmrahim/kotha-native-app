{
  "expo": {
    "name": "Kotha",
    "slug": "kotha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kotha",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D1117",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kotha.app",
      "backgroundColor": "#0D1117",
      "jsEngine": "hermes"
    },
    "android": {
      "backgroundColor": "#0D1117",
      "softwareKeyboardLayoutMode": "pan",
      "navigationBarColor": "#0D1117",
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#0D1117"
      },
      "package": "com.kotha.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.DISABLE_KEYGUARD",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.TURN_SCREEN_ON",
        "android.permission.SHOW_WHEN_LOCKED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withFloatingBubble",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#2DD4BF",
          "sounds": [
            "./assets/sound/received.mp3",
            "./assets/sound/send.mp3",
            "./assets/sound/typing.mp3",
            "./assets/sound/ringtun.mp3",
            "./assets/sound/ringing.mp3"
          ]
        }
      ],
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1117",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kotha to use your location."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Kotha to access your photos.",
          "savePhotosPermission": "Allow Kotha to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kotha to access your photos.",
          "cameraPermission": "Allow Kotha to use your camera."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Kotha to use your camera.",
          "microphonePermission": "Allow Kotha to use your microphone."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Kotha to access your contacts."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Kotha to record voice messages."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3546b7a0-20bc-4df8-b005-887216ea82b8"
      }
    }
  }
}